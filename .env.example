# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # set to your live Vercel URL in production

# ── TestSprite (used by dashboard API route + CI, NOT the browser) ──
TESTSPRITE_API_KEY=your-testsprite-api-key
TESTSPRITE_PROJECT_ID=proj_xxxxxxxx
